<!-- Modal for Room Section Start -->
<div id="modal-id" class="modal fade" tabindex="-1" role="dialog">
    <div class="modal-dialog modal-md modal-dialog-centered">
        <div class="modal-content modal-content-custom">
            <div class="modal-header modal-header-custom">
                <h5 class="modal-title text-white" id="modalRoomTitle">اتاق لوکس</h5>
            </div>
            <div class="modal-body p-0">
                <div class="modal-image-container">
                    <img id="modalRoomImage" class="img-fluid modal-image" src="@Url.Content("~/img/about/about-1.jpg")" alt="اتاق لوکس">
                </div>

                <div class="modal-content-text">
                    <h2 class="modal-room-title" id="modalRoomName">اتاق لوکس با چشم‌انداز شهر</h2>
                    <p class="modal-room-description">
                        این اتاق‌ها با طراحی مدرن و مبلمان راحت، دارای تلویزیون صفحه تخت، مینی‌بار، صندوق امن و سرویس بهداشتی مجزا با دوش و وان هستند. پنجره‌های بزرگ رو به شهر، نور طبیعی فراوانی را به داخل اتاق می‌آورند و منظره بی‌نظیری از شهر را به مهمانان هدیه می‌دهند.
                    </p>
                    <div class="modal-room-footer">
                        <a href="#" class="btn-book">رزرو کن</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
<!-- Modal for Room Section End -->


<script>
    function showRoomModal(imageSrc, title, price) {
        document.getElementById('modalRoomImage').src = imageSrc;
        document.getElementById('modalRoomTitle').textContent = title;
        document.getElementById('modalRoomName').textContent = title + ' - ' + price;
        $('#modal-id').modal('show');
    }
</script>

